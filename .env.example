# Figma personal access token (required).
# Create at: https://www.figma.com/developers/api#access-tokens
# Looks like: figd_<your-personal-access-token>
FIGMA_ACCESS_TOKEN=

# Figma REST API base URL (optional). Default: https://api.figma.com
# FIGMA_BASE_URL=https://api.figma.com

# Path to the Code Connect map file (optional). Default: ./figma.code-connect.json
# FIGMA_CODE_CONNECT_PATH=./figma.code-connect.json

# Path to a local variables export (optional). Unset = fetch live.
# FIGMA_VARIABLES_PATH=./figma.variables.json

# Directory for exported assets (optional). Default: ./figma-exports
# FIGMA_OUTPUT_DIR=./figma-exports

# --- Rate-limit / retry tuning (optional) ---
# How many times to retry a request after a 429 before giving up.
# Default 5 -> retries after ~1s, 2s, 4s, 8s of backoff.
# FIGMA_MAX_RETRIES=5

# Base backoff delay in ms. Doubles each retry (baseDelayMs * 2^attempt).
# Ignored when Figma sends a Retry-After header (that value wins). Default: 1000
# FIGMA_BASE_DELAY_MS=1000

# --- Response cache (optional) ---
# Caches Figma API responses on disk so repeated reads of the same file don't re-hit the API
# (the main rate-limit driver). On a 429 with no fresh entry, a stale entry is served instead.
# Set to "false" to always fetch live. Default: true (enabled).
# FIGMA_CACHE_ENABLED=true

# How long a cached entry stays fresh, in ms. A frozen file can use a long TTL.
# Default: 900000 (15 minutes).
# FIGMA_CACHE_TTL_MS=900000

# Oldest a cached entry may be and still be served on a 429 (rate limit). Beyond this the
# rate-limit error surfaces instead of returning data too old to trust. Default: 86400000 (24h).
# FIGMA_MAX_STALE_MS=86400000

# Directory for the on-disk cache. Default: ./.figma-cache (gitignored).
# NOTE: relative to the server's CWD, which the MCP client sets (often not the project dir).
# Set an absolute path to pin it. The resolved path is logged on startup.
# FIGMA_CACHE_DIR=./.figma-cache
